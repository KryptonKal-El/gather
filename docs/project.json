{
  "$schema": "https://opencode.ai/project.json",
  "name": "Gather",
  "description": "AI-powered grocery shopping list PWA with real-time sync, shared lists, recipes, and image search",
  "stack": {
    "language": "javascript",
    "framework": "react",
    "bundler": "vite",
    "styling": "css-modules",
    "backend": "supabase",
    "hosting": "vercel",
    "functions": "supabase-edge-functions",
    "database": "postgres",
    "auth": "supabase-auth",
    "pwa": true,
    "native": "capacitor"
  },
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "lint": "npm run lint",
    "preview": "npm run preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios"
  },
  "devPort": 4000,
  "paths": {
    "src": "src",
    "components": "src/components",
    "services": "src/services",
    "context": "src/context",
    "hooks": "src/hooks",
    "functions": "supabase/functions",
    "public": "public"
  },
  "capabilities": {
    "authentication": true,
    "realtime": true,
    "pwa": true,
    "imageSearch": true,
    "sharedLists": true,
    "recipes": true,
    "suggestions": true,
    "darkMode": true,
    "ios": true,
    "crud": true,
    "api": false,
    "multiTenant": false,
    "ai": false
  },
  "integrations": [
    {
      "name": "supabase",
      "purpose": "Auth, Postgres DB, Realtime, Storage, Edge Functions"
    },
    {
      "name": "walmart-affiliate",
      "purpose": "Primary product image search via Supabase Edge Function"
    },
    {
      "name": "openfoodfacts",
      "purpose": "Secondary fallback image search for grocery items (free, no API key)"
    },
    {
      "name": "serpapi",
      "purpose": "Tertiary fallback image search via Supabase Edge Function"
    },
    {
      "name": "capacitor",
      "purpose": "Native iOS app shell wrapping the React PWA for App Store distribution"
    }
  ],
  "git": {
    "defaultBranch": "main",
    "branchPattern": "gh/{ticket}/short-summary",
    "agentWorkflow": {
      "workBranch": "main",
      "pushTo": "main",
      "createPrTo": "main",
      "requiresHumanApproval": []
    },
    "teamSync": {
      "enabled": false
    }
  },
  "authentication": {
    "provider": "supabase",
    "method": "email-password",
    "acquisition": {
      "description": "Sign in with email/password via Supabase Auth",
      "steps": [
        "Navigate to the login page",
        "Enter test email and password",
        "Click Sign In",
        "Wait for redirect to main app view"
      ],
      "fallbackToUI": true
    }
  },
  "apps": [
    {
      "name": "web",
      "type": "web",
      "framework": "react-vite",
      "port": 4000
    },
    {
      "name": "ios-native",
      "type": "mobile",
      "framework": "swiftui"
    }
  ],
  "testing": {
    "testVerifySettings": {
      "adHocUIVerify_Analysis": true,
      "adHocUIVerify_StoryTest": true,
      "adHocUIVerify_CompletionTest": true,
      "prdUIVerify_Analysis": true,
      "prdUIVerify_StoryTest": true,
      "prdUIVerify_PRDCompletionTest": true
    }
  },
  "planning": {
    "considerations": []
  }
}
